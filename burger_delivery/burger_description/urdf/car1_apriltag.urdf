<?xml version="1.0"?>
<robot name="car1_apriltag">
  <material name="tag_white"><color rgba="1 1 1 1" /></material>
  <material name="cart_body"><color rgba="1 1 1 0.35" /></material>
  <material name="wheel_light"><color rgba="0.79216 0.81961 0.93333 1" /></material>
  <material name="caster_gray"><color rgba="0.63922 0.66667 0.67843 1" /></material>
  <material name="delivery_green"><color rgba="0.2 0.8 0.3 0.7" /></material>

  <link name="tag_carrito1">
    <visual name="apriltag_plate">
      <geometry><box size="0.10 0.10 0.001" /></geometry>
      <material name="tag_white" />
    </visual>
    <collision name="apriltag_collision">
      <geometry><box size="0.10 0.10 0.001" /></geometry>
    </collision>
  </link>

  <joint name="tag_carrito1_to_car1_base" type="fixed">
    <parent link="tag_carrito1" />
    <child link="car1_base_link" />
    <origin xyz="0.00 0.00 0.12" rpy="0 0 0" />
  </joint>

  <link name="car1_base_link">
    <inertial>
      <origin xyz="0.0100845530400964 -0.0000078763397840 -0.00660483212224633" rpy="0 0 0" />
      <mass value="0.128593928056721" />
      <inertia ixx="0.0000521456588109" ixy="0.0" ixz="0.0" iyy="0.000179567040468821" iyz="0.0" izz="0.00022799348701614" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/base_link.STL" /></geometry>
      <material name="cart_body" />
    </visual>
    <collision>
      <origin xyz="0.02 0 -0.02" rpy="0 0 0" />
      <geometry><box size="0.25 0.20 0.10" /></geometry>
    </collision>
  </link>

  <joint name="car1_Rueda_izquierda_Joint" type="continuous">
    <origin xyz="-0.033259 0.08025 -0.01375" rpy="-1.5708 0.042481 0" />
    <parent link="car1_base_link" />
    <child link="car1_Rueda_izquierda_Link" />
    <axis xyz="0 0 1" />
    <limit effort="100" velocity="100" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>
  <link name="car1_Rueda_izquierda_Link">
    <inertial>
      <origin xyz="0 0 -0.011873" rpy="0 0 0" />
      <mass value="0.021404" />
      <inertia ixx="0.0000086283" ixy="0.0" ixz="0.0" iyy="0.0000086269" iyz="0.0" izz="0.000014515" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/Rueda_izquierda_Link.STL" /></geometry>
      <material name="wheel_light" />
    </visual>
    <collision>
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/Rueda_izquierda_Link.STL" /></geometry>
    </collision>
  </link>

  <joint name="car1_Rueda_derecha_Joint" type="continuous">
    <origin xyz="-0.033259 -0.08025 -0.01375" rpy="1.5708 0.042481 -3.1416" />
    <parent link="car1_base_link" />
    <child link="car1_Rueda_derecha_Link" />
    <axis xyz="0 0 1" />
    <limit effort="100" velocity="100" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>
  <link name="car1_Rueda_derecha_Link">
    <inertial>
      <origin xyz="0 0 0.011873" rpy="0 0 0" />
      <mass value="0.021404" />
      <inertia ixx="0.0000086283" ixy="0.0" ixz="0.0" iyy="0.0000086269" iyz="0.0" izz="0.000014515" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/Rueda_derecha_Link.STL" /></geometry>
      <material name="wheel_light" />
    </visual>
    <collision>
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/Rueda_derecha_Link.STL" /></geometry>
    </collision>
  </link>

  <joint name="car1_Base_rueda_castor_Joint" type="continuous">
    <origin xyz="0.072581 0 -0.0025" rpy="3.1416 0 0" />
    <parent link="car1_base_link" />
    <child link="car1_Base_rueda_castor_Link" />
    <axis xyz="0 0 1" />
    <limit effort="100" velocity="100" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>
  <link name="car1_Base_rueda_castor_Link">
    <inertial>
      <origin xyz="0.0076868 -0.00024426 0.013506" rpy="0 0 0" />
      <mass value="0.013786" />
      <inertia ixx="0.0000012468" ixy="0.0" ixz="-0.00000024805" iyy="0.0000013131" iyz="0.0" izz="0.0000016977" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/Base_rueda_castor_Link.STL" /></geometry>
      <material name="caster_gray" />
    </visual>
    <collision>
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/Base_rueda_castor_Link.STL" /></geometry>
    </collision>
  </link>

  <joint name="car1_Rueda_castor_Joint" type="continuous">
    <origin xyz="0.015014 -0.00014167 0.02296" rpy="1.5708 -1.5708 0" />
    <parent link="car1_Base_rueda_castor_Link" />
    <child link="car1_Rueda_castor_Link" />
    <axis xyz="0 0 1" />
    <limit effort="100" velocity="100" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>
  <link name="car1_Rueda_castor_Link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0082874" />
      <inertia ixx="0.00000063927" ixy="0.0" ixz="0.0" iyy="0.0000006393" iyz="0.0" izz="0.0000010111" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/Rueda_castor_Link.STL" /></geometry>
      <material name="wheel_light" />
    </visual>
    <collision>
      <geometry><mesh filename="package://burger_description/visual/Carro2/meshes/Rueda_castor_Link.STL" /></geometry>
    </collision>
  </link>

  <joint name="car1_base_to_delivery_tray" type="fixed">
    <parent link="car1_base_link" />
    <child link="car1_delivery_tray_frame" />
    <origin xyz="0.00 0.00 0.08" rpy="0 0 0" />
  </joint>
  <link name="car1_delivery_tray_frame">
    <visual>
      <geometry><box size="0.16 0.16 0.02" /></geometry>
      <material name="delivery_green" />
    </visual>
    <collision>
      <geometry><box size="0.16 0.16 0.02" /></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="0.0001083" ixy="0.0" ixz="0.0" iyy="0.0001083" iyz="0.0" izz="0.0002133" />
    </inertial>
  </link>
</robot>
